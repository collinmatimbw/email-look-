{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    { "src": "/_/backend/(.*)", "dest": "backend/api/index.py" },
    { "src": "/(.*)", "dest": "frontend/$1" }
  ]
}
